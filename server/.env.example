DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
JWT_SECRET=replace-with-a-long-random-string
CLIENT_URL=*
PORT=8080

# Optional — enables calendar-invite emails for Action Plan control/completion dates.
# Leave unset and the app works fine, just without email reminders.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
